  46         BEGIN
  47                 dlg.setTitle("Suchen und Ersetzen");
  48                 iconPath := Rsrc + "Search.png";
  49                 dlg.setIconImage(Awt.Toolkit.getDefaultToolkit().getImage(dlg.getClass().getResource(iconPath)));
