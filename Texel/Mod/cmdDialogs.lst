  79                 dlg.checkGrossKlein.setBounds(5, 90, 300, 25);
  80                 comp := dlg.add(dlg.checkGrossKlein);
  81 
  82                 (* Button "Weitersuchen" *)
  83                 btn := Swing.JButton.Init("Weitersuchen");
  84                 btn.setFont(btn.getFont().deriveFont(Awt.Font.PLAIN, 11));
  85                 btn.setBounds(350, 5, 120, 25);
