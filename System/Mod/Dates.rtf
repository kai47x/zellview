N\par \tab \tab hook := h\par \tab END SetHook;\par \par \tab PROCEDURE  \b ValidTime\b0 * (IN t: Time): BOOLEAN;\par \tab BEGIN\par \tab \tab \b RETURN\b0 \par \tab \tab \tab (t.hour >= 0) & (t.hour <= 23)\par \tab \tab \tab & (t.minute >= 0) & (t.minute <= 59)\par \tab \tab \tab & (t.second >= 0) & (t.second <= 59)\par \tab END ValidTime;\par \tab \par \tab PROCEDURE \b ValidDate\b0 * (IN d: Date): BOOLEAN;\par \tab \tab VAR y, m, d1: INTEGER;\par \tab BEGIN\par \tab \tab IF (d.year < 1) OR (d.year > 9999) OR (d.month < 1) OR (d.month > 12) OR (d.day < 1) THEN\par \tab \tab \tab \b RETURN\b0  FALSE\par \tab \tab ELSE\par \tab \tab \tab y := d.year; m := d.month;\par \tab \tab \tab IF m = 2 THEN\par \tab \tab \tab \tab IF (y < 1583) & (y MOD 4 = 0)\par \tab \tab \tab \tab OR (y MOD 4 = 0) & ((y MOD 100 # 0) OR (y MOD 400 = 0)) THEN\par \tab \tab \tab \tab \tab d1 := 29\par \tab \tab \tab \tab ELSE d1 := 28\par \tab \tab \tab \tab END\par \tab \tab \tab ELSIF m IN \{1, 3, 5, 7, 8, 10, 12\} THEN d1 := 31\par \tab \tab \tab ELSE d1 := 30\par \tab \tab \tab END;\par \tab \tab \tab IF (y = 1582) & (m = 10) & (d.day > 4) & (d.day < 15) THEN \b RETURN\b0  FALSE END;\par \tab \tab \tab \b RETURN\b0  d.day <= d1\par \tab \tab END\par \tab END ValidDate;\par \par \tab PROCEDURE \b Day\b0 * (IN d: Date): INTEGER;\par \tab \tab VAR y, m, n: INTEGER;\par \tab BEGIN\par \tab \tab y := d.year; m := d.month - 3;\par \tab \tab IF m < 0 THEN INC(m, 12); DEC(y) END;\par \tab \tab n := y * 1461 DIV 4 + (m * 153 + 2) DIV 5 + d.day - 306;\par \tab \tab IF n > 577737 THEN n := n - (y DIV 100 * 3 - 5) DIV 4 END;\par \tab \tab RETURN n\par \tab END Day;\par \par \tab PROCEDURE \b DayToDate\b0 * (n: INTEGER; OUT d: Date);\par \tab \tab VAR c, y, m: INTEGER;\par \tab BEGIN\par \tab \tab IF n > 577737 THEN\par \tab \tab \tab n := n * 4 + 1215; c := n DIV 146097; n := n MOD 146097 DIV 4\par \tab \tab ELSE\par \tab \tab \tab n := n + 305; c := 0\par \tab \tab END;\par \tab \tab n := n * 4 + 3; y := n DIV 1461; n := n MOD 1461 DIV 4;\par \tab \tab n := n * 5 + 2; m := n DIV 153; n := n MOD 153 DIV 5;\par \tab \tab IF m > 9 THEN m := m - 12; INC(y) END;\par \tab \tab d.year := SHORT(100 * c + y);\par \tab \tab d.month := SHORT(m + 3);\par \tab \tab d.day := SHORT(n + 1)\par \tab END DayToDate;\par \par \tab PROCEDURE \b GetDate\b0 * (OUT d: Date);\par \tab \tab VAR t: Time;\par \tab BEGIN\par \tab \tab ASSERT(hook # NIL, 100);\par \tab \tab hook.GetTime(d, t)\par \tab END GetDate;\par \par \tab PROCEDURE \b GetTime\b0 * (OUT t: Time);\par \tab \tab VAR d: Date;\par \tab BEGIN\par \tab \tab ASSERT(hook # NIL, 100);\par \tab \tab hook.GetTime(d, t)\par \tab END GetTime;\par \par \i \tab (* UTC = Coordinated Universal Time, also konown as Greenwich Mean time (GMT). *)\par \i0 \par \tab PROCEDURE \b GetUTCDate\b0 * (OUT d: Date);\par \tab \tab VAR t: Time;\par \tab BEGIN\par \tab \tab ASSERT(hook # NIL, 100);\par \tab \tab hook.GetUTCTime(d, t)\par \tab END GetUTCDate;\par \par \tab PROCEDURE \b GetUTCTime\b0 * (OUT t: Time);\par \tab \tab VAR d: Date;\par \tab BEGIN\par \tab \tab ASSERT(hook # NIL, 100);\par \tab \tab hook.GetUTCTime(d, t)\par \tab END GetUTCTime;\par \tab \par \tab PROCEDURE \b GetUTCBias\b0 * (OUT bias: INTEGER);\par \i \tab (*\par \tab \tab Returns the current bias, in minutes, for local time translation on this computer. The bias is the difference, \par \tab \tab in minutes, between Coordinated Universal Time (UTC) and local time. All translations between UTC and\par \tab \tab local time are based on the following formula: \par \tab \tab \tab UTC = local time + bias \par  \tab *)\tab \tab \par \i0 \tab BEGIN\par \tab \tab ASSERT(hook # NIL, 100);\par \tab \tab hook.GetUTCBias(bias)\par \tab END GetUTCBias;\par \tab \par \pard\tx680\tx1077\tx1587 \par \tab \fs28 PROCEDURE \b GetEasterDate\b0 * (year: INTEGER; OUT d: Date);\par \tab VAR\par \tab \tab a, b, c, ,\par \tab \tab k, m, n, \par \tab \tab d0, \par \tab \tab e, o: INTEGER;\par \par \tab \tab month, day: INTEGER;\par \tab BEGIN\par \tab \tab ASSERT((year >= 1583) & (year <= 2299), 20);\par \par \tab \tab k := year DIV 100 - 15;\par \tab \tab \par \tab \tab m := M[k]; \par \tab \tab n := N[k];\par \tab \tab \par \tab \tab a := year MOD 19; \par \tab \tab b := year MOD 4; \par \tab \tab c := year MOD 7;\par \tab \tab d0 := (19*a + m) MOD 30; \par \tab \tab e := (2*b+4*c+6*d0+n) MOD 7;\par \tab \tab o := 21+d0+e; \par \tab \tab month := 3+o DIV 31; \par \tab \tab day := o MOD 31+1;\par \tab \tab IF month = 4 THEN\par \tab \tab \tab IF day = 26 THEN \par \tab \tab \tab \tab day := 19\par \tab \tab \tab ELSIF (day = 25) & (d0=28) & (e = 6) & (a > 10) THEN \par \tab \tab \tab \tab day := 18\par \tab \tab \tab END\par \tab \tab END;\par \tab \tab \par \tab \tab d.year := year;\par \tab \tab d.month := month;\par \tab \tab d.day := day\par \tab END GetEasterDate;\par \fs18 \par \tab PROCEDURE  \b DayOfWeek\b0 * (IN d: Date): INTEGER;\par \tab (** post: res = 0: Monday .. res = 6: Sunday **)\par \tab BEGIN\par \tab \tab \b RETURN\b0  SHORT((4+Day(d)) MOD 7)\par \tab END DayOfWeek;\par \par \tab PROCEDURE \b DateToString\b0 * (IN d: Date; format: INTEGER; OUT str: ARRAY OF CHAR);\par \tab BEGIN\par \tab \tab ASSERT(hook # NIL, 100);\par \tab \tab hook.DateToString(d, format, str)\par \tab END DateToString;\par \par \tab PROCEDURE \b TimeToString\b0 * (IN t: Time; OUT str: ARRAY OF CHAR);\par \tab BEGIN\par \tab \tab ASSERT(hook # NIL, 100);\par \tab \tab hook.TimeToString(t, str)\par \tab END TimeToString;\par \par BEGIN\par \tab M[0] := 22; N[0] := 2;\par \tab M[1] := 22; N[1] := 2;\par \tab M[2] := 23; N[2] := 3;\par \tab M[3] := 23; N[3] := 4;\par \tab M[4] := 24; N[4] := 5;\par \tab M[5] := 24; N[5] := 5;\par \tab M[6] := 24; N[6] := 6;\par \tab M[7] := 25; N[7] := 0;\par END Dates.\par 